class NetUtils:
    @staticmethod
    def check_connection():
        if SIMULATE: return True
        try:
            socket.create_connection(("8.8.8.8", 53), timeout=3)
            return True
        except OSError:
            return False

    @staticmethod
    def get_svg_data(name, to_white=False):
        url = f"https://raw.githubusercontent.com/feathericons/feather/master/icons/{name}.svg"
        try:
            with urllib.request.urlopen(url, timeout=3) as response:
                data = response.read()
                if to_white:
                    data = data.replace(b'currentColor', b'#ffffff')
                return data
        except:
            return None

class Sys:
    @staticmethod
    def run(cmd, input_text=None, check=True):
        try:
            r = subprocess.run(cmd, shell=True, check=check, text=True, input=input_text, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
            return r.stdout.strip()
        except: return None

    @staticmethod
    def list_disks():
        if SIMULATE: return [{"name": "sda", "size": "500G", "model": "VBOX HARDDISK", "type": "disk"}]
        o = Sys.run("lsblk -d -n -o NAME,SIZE,MODEL,TYPE -J", check=False)
        if o:
            try: return [d for d in json.loads(o)['blockdevices'] if d['type'] == 'disk']
            except: return []
        return []

    @staticmethod
    def get_uuid(dev):
        if SIMULATE and "sda" in dev: return f"UUID-for-{dev}"
        return Sys.run(f"blkid -s UUID -o value {dev}")

    @staticmethod
    def list_locales():
        try:
            with open('/usr/share/i18n/SUPPORTED', 'r') as f:
                return sorted([line.split()[0] for line in f if 'UTF-8' in line])
        except:
            return ["en_US.UTF-8", "pt_BR.UTF-8", "es_ES.UTF-8", "fr_FR.UTF-8", "de_DE.UTF-8"]

    @staticmethod
    def list_keymaps():
        out = Sys.run("localectl list-x11-keymap-layouts", check=False)
        if out: return sorted([l for l in out.split('\n') if l.strip()])
        return sorted(["us", "br", "pt", "es", "fr", "de", "it", "gb"])

    @staticmethod
    def list_timezones():
        out = Sys.run("timedatectl list-timezones", check=False)
        if out: return [t for t in out.split('\n') if t.strip()]
        return ["UTC", "America/New_York", "America/Sao_Paulo", "Europe/London", "Europe/Paris", "Europe/Berlin", "Europe/Madrid", "Asia/Tokyo"]

    @staticmethod
    def is_vm():
        r = Sys.run("systemd-detect-virt", check=False)
        return r != "none" if r else False

    @staticmethod
    def is_on_battery():
        p = "/sys/class/power_supply"
        if not os.path.exists(p): return False
        for supply in os.listdir(p):
            if supply.startswith("BAT"):
                status_path = os.path.join(p, supply, "status")
                if os.path.exists(status_path):
                    with open(status_path, 'r') as f:
                        if f.read().strip() == "Discharging": return True
        return False

class InstallWorker(QThread):
    log_msg = pyqtSignal(str)
    progress = pyqtSignal(int)
    finished = pyqtSignal(bool)

    def __init__(self, conf, locale):
        super().__init__()
        self.conf = conf
        self.sys_locale = locale
        self.mount = "/mnt/arvor"
        self.mapper = "cryptarvor"

    def run_cmd(self, cmd, input_text=None):
        self.log_msg.emit(f"== {cmd}")
        if SIMULATE: return True
        try:
            p = subprocess.Popen(cmd, shell=True, text=True, stdin=subprocess.PIPE, stdout=subprocess.PIPE, stderr=subprocess.STDOUT)
            if input_text:
                p.stdin.write(input_text + "\n")
                p.stdin.flush()
            for line in p.stdout:
                self.log_msg.emit(line.strip())
            p.wait()
            return p.returncode == 0
        except Exception as e:
            self.log_msg.emit(f"ERROR: {str(e)}")
            return False

    def simulate_install(self):
        sim_logs = ["==> wipefs -a /dev/sda", "==> parted -s /dev/sda mklabel gpt", "==> mount /dev/arvor_vg/root /mnt/tmp_install", "Installation complete."]
        delay = 10.0 / len(sim_logs)
        for i, msg in enumerate(sim_logs):
            self.log_msg.emit(msg)
            self.progress.emit(int((i + 1) / len(sim_logs) * 100))
            time.sleep(delay)
        self.progress.emit(100)
        self.finished.emit(True)

    def run(self):
        if SIMULATE:
            self.simulate_install()
            return

        self.progress.emit(0)
        d = self.conf["disk"]
        self.log_msg.emit("Starting disk partitioning...")
        self.run_cmd("vgchange -an arvor_vg || true")
        self.run_cmd(f"cryptsetup close {self.mapper} || true")
        self.run_cmd(f"wipefs -a -f {d}")

        self.run_cmd(f"parted -s {d} mklabel gpt")
        self.run_cmd(f"parted -s {d} mkpart ESP fat32 1MiB 513MiB")
        self.run_cmd(f"parted -s {d} set 1 esp on")
        self.run_cmd(f"parted -s {d} mkpart BOOT ext4 513MiB 1537MiB")
        self.run_cmd(f"parted -s {d} mkpart LVM 1537MiB 100%")
        
        self.run_cmd(f"partprobe {d}")
        self.run_cmd("udevadm settle")
        time.sleep(2)
        
        self.progress.emit(15)

        sep = "p" if "nvme" in d else ""
        p1, p2, p3 = f"{d}{sep}1", f"{d}{sep}2", f"{d}{sep}3"

        if self.conf["luks"]:
            self.run_cmd(f"cryptsetup luksFormat --type luks2 {p3} -", self.conf["luks_pass"])
            self.run_cmd(f"cryptsetup open {p3} {self.mapper} -", self.conf["luks_pass"])
            lvm_dev = f"/dev/mapper/{self.mapper}"
        else:
            lvm_dev = p3

        self.run_cmd(f"pvcreate -ff -y {lvm_dev}")
        self.run_cmd(f"vgcreate arvor_vg {lvm_dev}")
        pool_size = Sys.run("vgs --noheadings --units b -o vg_size arvor_vg 2>/dev/null | awk '{gsub(/B/,\"\"); print int($1 * 0.78)}'")
        pool_vsize = f"{int(pool_size) // (1024*1024)}M" if pool_size and pool_size.isdigit() else "10G"
        self.run_cmd(f"lvcreate -L {pool_vsize} -T arvor_vg/arvor_thin_pool")
        self.run_cmd(f"lvcreate -V {pool_vsize} -T arvor_vg/arvor_thin_pool -n root")
        self.run_cmd("lvchange -ay arvor_vg/root")
        self.run_cmd("udevadm settle")

        root_dev = "/dev/mapper/arvor_vg-root"

        self.run_cmd(f"mkfs.vfat -F32 {p1}")
        self.run_cmd(f"mkfs.ext4 -F {p2}")
        self.run_cmd(f"mkfs.xfs -f {root_dev}")
              
        self.run_cmd("udevadm settle")
        time.sleep(2)
        self.progress.emit(25)

        u_root = Sys.get_uuid(root_dev)
        u_boot = Sys.get_uuid(p2)
        u_efi = Sys.get_uuid(p1)
        u_p3 = Sys.get_uuid(p3) if self.conf["luks"] else ""
        f_root = f"UUID={u_root}" if u_root else root_dev
        f_boot = f"UUID={u_boot}" if u_boot else p2
        f_efi = f"UUID={u_efi}" if u_efi else p1
        f_p3 = f"UUID={u_p3}" if u_p3 else p3

        if "UUID=" not in f_root:
            self.log_msg.emit("WARNING: UUID detection failed, using absolute paths in fstab.")

        self.progress.emit(30)

        os.makedirs(self.mount, exist_ok=True)
        self.run_cmd(f"mount {root_dev} {self.mount}")
        os.makedirs(f"{self.mount}/boot", exist_ok=True)
        self.run_cmd(f"mount {p2} {self.mount}/boot")
        os.makedirs(f"{self.mount}/boot/efi", exist_ok=True)
        self.run_cmd(f"mount {p1} {self.mount}/boot/efi")

        if not self.run_cmd(f"debootstrap --arch=amd64 trixie {self.mount} http://deb.debian.org/debian"):
            self.finished.emit(False)
            return
        self.progress.emit(55)

        self.run_cmd(f"wget -O {self.mount}/tmp/nextferret-base.deb https://github.com/NextFerret/arvor/releases/download/basenotiso5/nf-base_3.0.0_amd64.deb")
        for m in ["/dev", "/dev/pts", "/proc", "/sys", "/run"]:
            self.run_cmd(f"mount --bind {m} {self.mount}{m}")
            
        shutil.copy("/etc/resolv.conf", f"{self.mount}/etc/resolv.conf")

        if os.path.exists("/etc/apt/preferences.d/nextferret"):
            os.makedirs(f"{self.mount}/etc/apt/preferences.d", exist_ok=True)
            shutil.copy2("/etc/apt/preferences.d/nextferret", f"{self.mount}/etc/apt/preferences.d/nextferret")

        for file_path in FILES:
            if os.path.exists(file_path):
                dst = f"{self.mount}{file_path}"
                os.makedirs(os.path.dirname(dst), exist_ok=True)
                if os.path.islink(file_path):
                    if os.lexists(dst): os.remove(dst)
                    os.symlink(os.readlink(file_path), dst)
                else:
                    shutil.copy2(file_path, dst)
                    if "bin" in file_path:
                        self.run_cmd(f"chmod +x {dst}")

        if os.path.exists("/etc/motd"):
            try:
                os.makedirs(f"{self.mount}/etc", exist_ok=True)
                with open("/etc/motd", "r") as src, open(f"{self.mount}/etc/motd", "w") as dst:
                    dst.write(src.read())
            except: pass

        if os.path.exists("/usr/lib/os-release"):
            os.makedirs(f"{self.mount}/usr/lib", exist_ok=True)
            shutil.copy2("/usr/lib/os-release", f"{self.mount}/usr/lib/os-release")
        elif os.path.exists("/etc/os-release"):
            os.makedirs(f"{self.mount}/usr/lib", exist_ok=True)
            with open("/etc/os-release", "r") as src, open(f"{self.mount}/usr/lib/os-release", "w") as dst:
                dst.write(src.read())

        if os.path.lexists(f"{self.mount}/etc/os-release"):
            os.remove(f"{self.mount}/etc/os-release")
        os.symlink("../usr/lib/os-release", f"{self.mount}/etc/os-release")

        for osf in ["/etc/lsb-release", "/etc/issue", "/etc/issue.net", "/etc/debian_version", "/usr/share/nextferret/credits.txt"]:
            if os.path.lexists(osf):
                dst = f"{self.mount}{osf}"
                os.makedirs(os.path.dirname(dst), exist_ok=True)
                if os.path.lexists(dst): os.remove(dst)
                if os.path.islink(osf): os.symlink(os.readlink(osf), dst)
                else: shutil.copy2(osf, dst)

        luks_sh = f"echo '{self.mapper} {f_p3} none luks,discard,initramfs' > /etc/crypttab\napt-get install -y cryptsetup-initramfs\n" if self.conf["luks"] else ""
        de_sh = f"apt-get install -y -o Dpkg::Options::=--force-confdef -o Dpkg::Options::=--force-confold {self.conf['de_pkgs']}\n" if self.conf["de_pkgs"] else ""

        fstab_sh = f"""
cat << EOF > /etc/fstab
{f_root} /               xfs     defaults        0       0
{f_boot} /boot           ext4    defaults        0       2
{f_efi}  /boot/efi       vfat    defaults        0       1
EOF
"""

        script = f"""#!/bin/bash
set -e
export DEBIAN_FRONTEND=noninteractive

if [ -e /etc/motd ] || [ -L /etc/motd ]; then
    cp -a /etc/motd /etc/motd.custom_bak
fi
dpkg-divert --package nextferret-core --add --rename --divert /etc/debian_motd /etc/motd || true
if [ -e /etc/motd.custom_bak ]; then
    mv /etc/motd.custom_bak /etc/motd
fi

echo "deb http://deb.debian.org/debian trixie main contrib non-free non-free-firmware" > /etc/apt/sources.list
echo "deb http://security.debian.org/debian-security trixie-security main contrib non-free" >> /etc/apt/sources.list

mkdir -p /etc/apt/preferences.d
cat << 'EOF' > /etc/apt/preferences.d/99-block-desktop-base
Package: desktop-base
Pin: release *
Pin-Priority: -2
EOF


for f in /etc/os-release /usr/lib/os-release /etc/lsb-release /etc/issue /etc/issue.net /etc/debian_version; do
    if [ -e "$f" ] || [ -L "$f" ]; then
        cp -a "$f" "$f.custom_bak"
        dpkg-divert --add --package nextferret-core --rename --divert "$f.distrib" "$f" || true
        mv "$f.custom_bak" "$f"
    fi
done

apt-get update

if [ -f /tmp/nextferret-base.deb ]; then
    apt-get install -y --no-install-recommends /tmp/nextferret-base.deb
fi

dpkg-divert --add --package nextferret-core --rename --divert /usr/bin/old-apt /usr/bin/apt
ln -sf /usr/bin/napt /usr/bin/apt

apt-get install -y --no-install-recommends debootstrap python3 linux-image-amd64 sudo network-manager firmware-linux grub-efi-amd64-signed shim-signed locales keyboard-configuration console-setup ca-certificates plymouth plymouth-themes lvm2 xfsprogs grub-common gawk inotify-tools git make efibootmgr curl xz-utils

sed -i "s/^# *{self.sys_locale}/{self.sys_locale}/" /etc/locale.gen || true
locale-gen || true
echo "LANG={self.sys_locale}" > /etc/default/locale

echo 'XKBLAYOUT="{self.conf["keymap"]}"' > /etc/default/keyboard
dpkg-reconfigure -f noninteractive keyboard-configuration

ln -sf /usr/share/zoneinfo/{self.conf["timezone"]} /etc/localtime
systemctl enable NetworkManager

{luks_sh}

userdel -r live 2>/dev/null || true
useradd -m -s /bin/bash -G sudo {self.conf['user']}
echo "{self.conf['user']}:{self.conf['pass']}" | chpasswd
echo "root:{self.conf['pass']}" | chpasswd
echo "{self.conf['hostname']}" > /etc/hostname
echo "127.0.0.1    localhost" > /etc/hosts
echo "::1          localhost ip6-localhost ip6-loopback" >> /etc/hosts
echo "127.0.1.1    {self.conf['hostname']}" >> /etc/hosts

{de_sh}
{fstab_sh}

if [ -d "/usr/share/plymouth/themes/blockchain" ]; then
    plymouth-set-default-theme blockchain || true
fi

mkdir -p /etc/initramfs-tools/conf.d
echo "RESUME=none" > /etc/initramfs-tools/conf.d/resume
echo "MODULES=most" > /etc/initramfs-tools/conf.d/modules

mkdir -p /etc/initramfs-tools/hooks
cat << 'HOOK' > /etc/initramfs-tools/hooks/lvm2
#!/bin/sh
PREREQS=""
prereqs() {{ echo "$PREREQS"; }}
case "$1" in prereqs) prereqs; exit 0;; esac
. /usr/share/initramfs-tools/hook-functions
copy_exec /sbin/lvm /sbin
copy_exec /sbin/lvchange /sbin
copy_exec /sbin/vgchange /sbin
manual_add_modules dm-thin-pool dm_thin_pool dm-mod
HOOK
chmod +x /etc/initramfs-tools/hooks/lvm2

mkdir -p /etc/initramfs-tools/scripts/local-top
cat << 'SCRIPT' > /etc/initramfs-tools/scripts/local-top/activate_lvm
#!/bin/sh
PREREQS="lvm2"
prereqs() {{ echo "$PREREQS"; }}
case "$1" in prereqs) prereqs; exit 0;; esac
vgchange -ay arvor_vg || true
SCRIPT
chmod +x /etc/initramfs-tools/scripts/local-top/activate_lvm

touch /etc/default/grub

sed -i 's|^GRUB_CMDLINE_LINUX=.*|GRUB_CMDLINE_LINUX="rd.lvm.lv=arvor_vg/root"|' /etc/default/grub || true
grep -q "rd.lvm.lv" /etc/default/grub || echo 'GRUB_CMDLINE_LINUX="rd.lvm.lv=arvor_vg/root"' >> /etc/default/grub

rm -rf /etc/motd

update-initramfs -c -k all || update-initramfs -u

grub-install \
    --target=x86_64-efi \
    --efi-directory=/boot/efi \
    --bootloader-id=ArvorLinux \
    --recheck

update-grub || true

efibootmgr --create \
    --disk {disk} \
    --part 1 \
    --label "Arvor Linux" \
    --loader '\\EFI\\ArvorLinux\\grubx64.efi' || true

lvmabd_start 1 &
napt sync
apt-get clean
rm /s.sh
exit 0
"""
        chroot_script_path = os.path.join(self.mount, "s.sh")
        with open(chroot_script_path, "w") as f: f.write(script)
        self.run_cmd(f"chmod +x {chroot_script_path}")
        self.run_cmd(f"chroot {self.mount} /s.sh")
        self.progress.emit(95)

        for m in ["/run", "/sys", "/proc", "/dev/pts", "/dev"]: 
            self.run_cmd(f"umount -l {self.mount}{m}")
            
        try: self.run_cmd(f"umount -R {self.mount}")
        except: self.run_cmd(f"umount -l {self.mount}")

        self.run_cmd("vgchange -an arvor_vg || true")
        if self.conf["luks"]: self.run_cmd(f"cryptsetup close {self.mapper}")

        self.progress.emit(100)
        self.finished.emit(True)


class InstallerGUI(QMainWindow):
    def __init__(self):
        super().__init__()
        self.ui_lang = "en"
        self.sys_locale = "en_US.UTF-8"
        self.conf = {
            "hostname": "arvor", "disk": None, "user": "", "pass": "",
            "luks": False, "luks_pass": "", "keymap": "us", "timezone": "UTC",
            "de_name": "None", "de_pkgs": ""
        }
        self.desktops = [
            ("None (CLI)", ""), ("XFCE", "xfce4 xfce4-goodies lightdm"), ("GNOME", "gnome-core gdm3"),
            ("KDE Plasma", "kde-standard sddm"), ("Cinnamon", "cinnamon-core lightdm"),
            ("MATE", "mate-desktop-environment lightdm"), ("LXQt", "lxqt-core sddm")
        ]
        self.lang_map = {
            0: ("en", "en_US.UTF-8", "us", "UTC"), 1: ("pt", "pt_BR.UTF-8", "br", "America/Sao_Paulo"),
            2: ("es", "es_ES.UTF-8", "es", "Europe/Madrid"), 3: ("fr", "fr_FR.UTF-8", "fr", "Europe/Paris"),
            4: ("de", "de_DE.UTF-8", "de", "Europe/Berlin"), 5: ("gl", "gl_ES.UTF-8", "gl", "Europe/Madrid")
        }

        self.list_of_locales = Sys.list_locales()
        self.list_of_keymaps = Sys.list_keymaps()
        self.list_of_timezones = Sys.list_timezones()
        self.icon_cache = {}
        self.sidebar_icon_cache = {}

        self.steps = ["step_welcome", "step_location", "step_keyboard", "step_desktop",
                      "step_partitions", "step_users", "step_summary", "step_install", "step_finish"]
        self.step_keys = ["welcome", "location", "keyboard", "software", "disk", "users", "summary", "install", "finish"]

        self.preload_icons()
        self.init_ui()

    def t(self, key):
        return TEXT[self.ui_lang].get(key, key)

    def preload_icons(self):
        sidebar_icons = {"welcome": "smile", "location": "map-pin", "keyboard": "grid", "software": "package", "disk": "hard-drive", "users": "users", "summary": "file-text", "install": "download-cloud", "finish": "check-circle"}
        for k, v in sidebar_icons.items():
            data = NetUtils.get_svg_data(v, to_white=True)
            if data:
                pm = QPixmap()
                pm.loadFromData(data)
                self.sidebar_icon_cache[k] = QIcon(pm)

        nav_icons = {"next": "arrow-right", "back": "arrow-left", "install_btn": "download", "check_btn": "check"}
        for k, v in nav_icons.items():
            data = NetUtils.get_svg_data(v, to_white=False)
            if data:
                pm = QPixmap()
                pm.loadFromData(data)
                self.icon_cache[k] = QIcon(pm)

    def get_sidebar_icon(self, name): return self.sidebar_icon_cache.get(name, QIcon())
    def get_nav_icon(self, name): return self.icon_cache.get(name, QIcon())

    def init_ui(self):
        self.setWindowTitle(self.t("title"))
        self.setMinimumSize(1150, 750)

        main_widget = QWidget()
        main_layout = QHBoxLayout()
        main_layout.setContentsMargins(0, 0, 0, 0)
        main_layout.setSpacing(0)

        self.sidebar = QListWidget()
        self.sidebar.setFixedWidth(280)
        self.sidebar.setFocusPolicy(Qt.FocusPolicy.NoFocus)
        self.sidebar.setAttribute(Qt.WidgetAttribute.WA_TransparentForMouseEvents)

        for i, s in enumerate(self.steps):
            item = QListWidgetItem(self.get_sidebar_icon(self.step_keys[i]), self.t(s))
            self.sidebar.addItem(item)

        main_layout.addWidget(self.sidebar)

        right_panel = QWidget()
        right_layout = QVBoxLayout()
        right_layout.setContentsMargins(50, 50, 50, 40)

        self.stack = QStackedWidget()
        self.build_pages()
        right_layout.addWidget(self.stack)

        self.nav_container = self.create_nav_bar()
        right_layout.addSpacing(25)
        right_layout.addWidget(self.nav_container)

        right_panel.setLayout(right_layout)
        main_layout.addWidget(right_panel)
        main_widget.setLayout(main_layout)
        self.setCentralWidget(main_widget)

        self.update_sidebar()
        self.btn_back.setEnabled(False)

    def build_pages(self):
        self.stack.addWidget(self.create_welcome_page())
        self.stack.addWidget(self.create_location_page())
        self.stack.addWidget(self.create_keyboard_page())
        self.stack.addWidget(self.create_desktop_page())
        self.stack.addWidget(self.create_partitions_page())
        self.stack.addWidget(self.create_users_page())
        self.stack.addWidget(self.create_summary_page())
        self.stack.addWidget(self.create_install_page())
        self.stack.addWidget(self.create_finish_page())

    def create_nav_bar(self):
        nav_frame = QFrame()
        nav_frame.setProperty("card", "true")
        shadow = QGraphicsDropShadowEffect()
        shadow.setBlurRadius(30)
        shadow.setColor(QColor(0, 0, 0, 20))
        shadow.setOffset(0, 6)
        nav_frame.setGraphicsEffect(shadow)
        nav_layout = QHBoxLayout()
        nav_layout.setContentsMargins(25, 20, 25, 20)
        self.btn_back = QPushButton(self.get_nav_icon("back"), self.t("back"))
        self.btn_next = QPushButton(self.get_nav_icon("next"), self.t("next"))
        self.btn_next.setLayoutDirection(Qt.LayoutDirection.RightToLeft)
        self.btn_next.setProperty("primary", "true")
        self.btn_next.setCursor(Qt.CursorShape.PointingHandCursor)
        self.btn_back.setCursor(Qt.CursorShape.PointingHandCursor)
        self.btn_back.clicked.connect(self.go_back)
        self.btn_next.clicked.connect(self.go_next)
        nav_layout.addStretch()
        nav_layout.addWidget(self.btn_back)
        nav_layout.addSpacing(15)
        nav_layout.addWidget(self.btn_next)
        nav_frame.setLayout(nav_layout)
        return nav_frame

    def update_sidebar(self):
        idx = self.stack.currentIndex()
        for i in range(self.sidebar.count()):
            self.sidebar.item(i).setSelected(i == idx)

    def create_title(self, text_key, sub_key=None):
        container = QWidget()
        l = QVBoxLayout()
        l.setContentsMargins(0,0,0,25)
        lbl = QLabel(self.t(text_key))
        lbl.setProperty("text_key", text_key)
        lbl.setProperty("heading", "true")
        l.addWidget(lbl)
        if sub_key:
            sub = QLabel(self.t(sub_key))
            sub.setProperty("text_key", sub_key)
            sub.setProperty("subheading", "true")
            l.addWidget(sub)
        container.setLayout(l)
        return container

    def _create_card(self):
        card = QFrame()
        card.setProperty("card", "true")
        cl = QVBoxLayout()
        cl.setContentsMargins(25, 25, 25, 25)
        card.setLayout(cl)
        return card, cl

    def _create_label(self, text_key, style="font-weight: 600; color: #334155; margin-bottom: 5px; margin-top: 10px;"):
        lbl = QLabel(self.t(text_key))
        lbl.setStyleSheet(style)
        return lbl

    def _create_alert(self, msg_key, alert_type):
        f = QFrame()
        f.setProperty("alert", alert_type)
        hl = QHBoxLayout()
        lbl = QLabel(self.t(msg_key))
        lbl.setProperty("alert-text", alert_type)
        hl.addWidget(lbl)
        hl.addStretch()
        f.setLayout(hl)
        return f

    def create_welcome_page(self):
        w = QWidget()
        l = QVBoxLayout()
        l.addWidget(self.create_title("welcome_msg", "welcome_sub"))

        if Sys.is_vm() and not SIMULATE:
            l.addWidget(self._create_alert("warn_vm", "warning"))
            l.addSpacing(15)

        if Sys.is_on_battery() and not SIMULATE:
            l.addWidget(self._create_alert("warn_power", "danger"))

        card, cl = self._create_card()
        lbl_lang = self._create_label("locale")
        self.c_lang = QComboBox()
        self.c_lang.addItems(["English", "Português (Brasil)", "Español", "Français", "Deutsch", "Galego"])
        self.c_lang.currentIndexChanged.connect(self.change_language)

        cl.addWidget(lbl_lang)
        cl.addWidget(self.c_lang)
        l.addWidget(card)
        l.addStretch()
        w.setLayout(l)
        return w

    def change_language(self, index):
        if index in self.lang_map:
            lang, loc, keymap, tz = self.lang_map[index]
            self.ui_lang = lang
            self.sys_locale = loc
            self.conf["keymap"] = keymap
            self.conf["timezone"] = tz

        self.c_locale.setCurrentText(self.sys_locale)
        self.c_key.setCurrentText(self.conf["keymap"])
        self.i_tz.setCurrentText(self.conf["timezone"])

        self.setWindowTitle(self.t("title"))
        self.update_sidebar()

        for i, s in enumerate(self.steps):
            self.sidebar.item(i).setText(self.t(s))

        self.lbl_loc.setText(self.t("locale"))
        self.lbl_tz.setText(self.t("tz"))
        self.lbl_key.setText(self.t("keymap"))
        self.lbl_de.setText(self.t("de"))
        self.lbl_disk.setText(self.t("disk"))
        self.chk_luks.setText(self.t("luks"))
        self.lbl_luks_p.setText(self.t("luks_p"))
        self.lbl_host.setText(self.t("host"))
        self.lbl_user.setText(self.t("user_name"))
        self.lbl_pass.setText(self.t("pass"))
        self.lbl_pass_c.setText(self.t("pass_c"))

        self.btn_back.setText(self.t("back"))
        idx = self.stack.currentIndex()
        if idx == 6: self.btn_next.setText(self.t("install"))
        elif idx == 8: self.btn_next.setText(self.t("quit"))
        else: self.btn_next.setText(self.t("next"))

        for i in range(self.stack.count()):
            page = self.stack.widget(i)
            for child in page.findChildren(QLabel):
                if child.property("text_key"):
                    child.setText(self.t(child.property("text_key")))

    def create_location_page(self):
        w = QWidget()
        l = QVBoxLayout()
        l.addWidget(self.create_title("step_location"))
        card, cl = self._create_card()

        self.lbl_loc = self._create_label("locale")
        self.c_locale = QComboBox()
        self.c_locale.addItems(self.list_of_locales)
        self.c_locale.setCurrentText(self.sys_locale)

        self.lbl_tz = self._create_label("tz")
        self.i_tz = QComboBox()
        self.i_tz.addItems(self.list_of_timezones)
        self.i_tz.setCurrentText(self.conf["timezone"])

        cl.addWidget(self.lbl_loc)
        cl.addWidget(self.c_locale)
        cl.addWidget(self.lbl_tz)
        cl.addWidget(self.i_tz)

        l.addWidget(card)
        l.addStretch()
        w.setLayout(l)
        return w

    def create_keyboard_page(self):
        w = QWidget()
        l = QVBoxLayout()
        l.addWidget(self.create_title("step_keyboard"))
        card, cl = self._create_card()

        self.lbl_key = self._create_label("keymap")
        self.c_key = QComboBox()
        self.c_key.addItems(self.list_of_keymaps)
        self.c_key.setCurrentText(self.conf["keymap"])

        cl.addWidget(self.lbl_key)
        cl.addWidget(self.c_key)
        l.addWidget(card)
        l.addStretch()
        w.setLayout(l)
        return w

    def create_desktop_page(self):
        w = QWidget()
        l = QVBoxLayout()
        l.addWidget(self.create_title("step_desktop"))
        card, cl = self._create_card()

        self.lbl_de = self._create_label("de")
        self.c_de = QComboBox()
        for d in self.desktops: self.c_de.addItem(d[0], d[1])

        cl.addWidget(self.lbl_de)
        cl.addWidget(self.c_de)
        l.addWidget(card)
        l.addStretch()
        w.setLayout(l)
        return w

    def create_partitions_page(self):
        w = QWidget()
        l = QVBoxLayout()
        l.addWidget(self.create_title("step_partitions"))
        card, cl = self._create_card()

        self.lbl_disk = self._create_label("disk")
        self.c_disk = QComboBox()
        for d in Sys.list_disks(): self.c_disk.addItem(f"{d['model']} ({d['size']}) - {d['name']}", f"/dev/{d['name']}")

        cl.addWidget(self.lbl_disk)
        cl.addWidget(self.c_disk)
        cl.addSpacing(20)

        line = QFrame()
        line.setFrameShape(QFrame.Shape.HLine)
        line.setStyleSheet("background-color: #f1f5f9; height: 1px;")
        cl.addWidget(line)
        cl.addSpacing(20)

        self.chk_luks = QCheckBox(self.t("luks"))
        self.chk_luks.setStyleSheet("font-weight: 600; color: #334155; margin-bottom: 5px;")
        self.lbl_luks_p = self._create_label("luks_p", "font-weight: 600; color: #64748b; margin-top: 10px; margin-bottom: 5px;")
        self.i_luks_p = QLineEdit()
        self.i_luks_p.setEchoMode(QLineEdit.EchoMode.Password)
        self.i_luks_p.setEnabled(False)
        self.chk_luks.toggled.connect(self.i_luks_p.setEnabled)

        cl.addWidget(self.chk_luks)
        cl.addWidget(self.lbl_luks_p)
        cl.addWidget(self.i_luks_p)

        l.addWidget(card)
        l.addStretch()
        w.setLayout(l)
        return w

    def create_users_page(self):
        w = QWidget()
        l = QVBoxLayout()
        l.addWidget(self.create_title("step_users"))
        card, cl = self._create_card()

        self.lbl_user = self._create_label("user_name")
        self.i_user = QLineEdit()
        self.lbl_host = self._create_label("host")
        self.i_host = QLineEdit(self.conf["hostname"])
        self.lbl_pass = self._create_label("pass")
        self.i_pass = QLineEdit()
        self.i_pass.setEchoMode(QLineEdit.EchoMode.Password)
        self.lbl_pass_c = self._create_label("pass_c")
        self.i_pass_c = QLineEdit()
        self.i_pass_c.setEchoMode(QLineEdit.EchoMode.Password)

        for widget in [self.lbl_user, self.i_user, self.lbl_host, self.i_host, self.lbl_pass, self.i_pass, self.lbl_pass_c, self.i_pass_c]:
            cl.addWidget(widget)

        l.addWidget(card)
        l.addStretch()
        w.setLayout(l)
        return w

    def create_summary_page(self):
        w = QWidget()
        l = QVBoxLayout()
        l.addWidget(self.create_title("step_summary"))

        self.lbl_sum_warn = QLabel(self.t("summary_warn"))
        self.lbl_sum_warn.setStyleSheet("background-color: #fef2f2; color: #991b1b; padding: 20px; border-radius: 12px; font-weight: 600; border: 1px solid #fca5a5; font-size: 15px;")
        self.lbl_sum_warn.setWordWrap(True)

        self.lbl_sum_text = QTextEdit()
        self.lbl_sum_text.setReadOnly(True)
        self.lbl_sum_text.setStyleSheet("border: 1px solid #e2e8f0; border-radius: 12px; padding: 20px; background-color: white; font-size: 15px;")

        l.addWidget(self.lbl_sum_warn)
        l.addSpacing(15)
        l.addWidget(self.lbl_sum_text)
        w.setLayout(l)
        return w

    def populate_summary(self):
        html = f"""
        <style>
            h3 {{ color: #0f172a; margin-bottom: 8px; font-size: 17px; font-family: -apple-system, sans-serif; font-weight: 700; }}
            p {{ color: #475569; margin-top: 0; margin-bottom: 18px; font-family: -apple-system, sans-serif; font-size: 15px; }}
            hr {{ border: 0; border-top: 1px solid #f1f5f9; margin: 15px 0; }}
        </style>
        <h3>{self.t("step_location")}</h3><p>{self.sys_locale} • {self.conf['timezone']}</p><hr>
        <h3>{self.t("step_keyboard")}</h3><p>{self.conf['keymap']}</p><hr>
        <h3>{self.t("step_desktop")}</h3><p>{self.conf['de_name']}</p><hr>
        <h3>{self.t("step_partitions")}</h3><p>{self.conf['disk']} <br>LUKS: {'Enabled' if self.conf['luks'] else 'Disabled'}</p><hr>
        <h3>{self.t("step_users")}</h3><p>{self.conf['user']} @ {self.conf['hostname']}</p>
        """
        self.lbl_sum_text.setHtml(html)

    def create_install_page(self):
        w = QWidget()
        l = QVBoxLayout()
        l.addWidget(self.create_title("step_install"))

        self.pbar = QProgressBar()
        self.pbar.setRange(0, 100)
        self.pbar.setValue(0)

        self.txt_log = QTextEdit()
        self.txt_log.setProperty("log", "true")
        self.txt_log.setReadOnly(True)

        l.addWidget(self.pbar)
        l.addSpacing(25)
        l.addWidget(self.txt_log)
        w.setLayout(l)
        return w

    def create_finish_page(self):
        w = QWidget()
        l = QVBoxLayout()
        l.setAlignment(Qt.AlignmentFlag.AlignCenter)

        icon_lbl = QLabel()
        pm = self.get_nav_icon("check_btn").pixmap(100, 100)
        if pm.isNull():
             icon_lbl.setText("✓")
             icon_lbl.setStyleSheet("font-size: 100px; color: #22c55e;")
        else:
            icon_lbl.setPixmap(pm)
        icon_lbl.setAlignment(Qt.AlignmentFlag.AlignCenter)

        title = QLabel(self.t("finish_msg"))
        title.setProperty("heading", "true")
        title.setAlignment(Qt.AlignmentFlag.AlignCenter)

        sub = QLabel(self.t("finish_sub"))
        sub.setProperty("subheading", "true")
        sub.setAlignment(Qt.AlignmentFlag.AlignCenter)
        sub.setWordWrap(True)

        l.addStretch()
        l.addWidget(icon_lbl)
        l.addSpacing(35)
        l.addWidget(title)
        l.addWidget(sub)
        l.addStretch()
        w.setLayout(l)
        return w

    def validate_current_page(self):
        idx = self.stack.currentIndex()
        if idx == 1:
            self.sys_locale = self.c_locale.currentText()
            self.conf["timezone"] = self.i_tz.currentText()
        elif idx == 2:
            self.conf["keymap"] = self.c_key.currentText()
        elif idx == 3:
            self.conf["de_name"] = self.c_de.currentText()
            self.conf["de_pkgs"] = self.c_de.currentData()
        elif idx == 4:
            if self.c_disk.currentIndex() == -1:
                QMessageBox.warning(self, "Error", self.t("err_disk"))
                return False
            if self.chk_luks.isChecked() and not self.i_luks_p.text():
                QMessageBox.warning(self, "Error", self.t("err_pass"))
                return False
            self.conf["disk"] = self.c_disk.currentData()
            self.conf["luks"] = self.chk_luks.isChecked()
            self.conf["luks_pass"] = self.i_luks_p.text()
        elif idx == 5:
            user = self.i_user.text().strip()
            host = self.i_host.text().strip()
            if not user or not host:
                QMessageBox.warning(self, "Error", self.t("err_user"))
                return False
            p1, p2 = self.i_pass.text(), self.i_pass_c.text()
            if not p1 or p1 != p2:
                QMessageBox.warning(self, "Error", self.t("err_pass"))
                return False
            self.conf["user"] = user
            self.conf["hostname"] = host
            self.conf["pass"] = p1
        return True

    def update_progress(self, value):
        self.pbar.setValue(value)

    def go_next(self):
        idx = self.stack.currentIndex()
        if not self.validate_current_page(): return

        if idx == 5:
            self.populate_summary()
            self.btn_next.setText(self.t("install"))
            self.btn_next.setIcon(self.get_nav_icon("install_btn"))
            self.btn_next.setProperty("primary", "true")
            self.apply_styles()
        elif idx == 6:
            self.start_install()
            return
        elif idx == 8:
            Sys.run("reboot")
            sys.exit(0)

        self.stack.setCurrentIndex(idx + 1)
        self.btn_back.setEnabled(True)
        self.update_sidebar()

        if self.stack.currentIndex() not in (6, 8):
            self.btn_next.setText(self.t("next"))
            self.btn_next.setIcon(self.get_nav_icon("next"))
            self.btn_next.setProperty("primary", "true")
            self.apply_styles()

    def go_back(self):
        idx = self.stack.currentIndex()
        if idx > 0:
            self.stack.setCurrentIndex(idx - 1)
            self.update_sidebar()
            self.btn_next.setText(self.t("next"))
            self.btn_next.setIcon(self.get_nav_icon("next"))
            self.btn_next.setProperty("primary", "true")
            self.apply_styles()
            if self.stack.currentIndex() == 0:
                self.btn_back.setEnabled(False)

    def start_install(self):
        self.stack.setCurrentIndex(7)
        self.update_sidebar()
        self.nav_container.hide()

        self.worker = InstallWorker(self.conf, self.sys_locale)
        self.worker.log_msg.connect(self.txt_log.append)
        self.worker.progress.connect(self.update_progress)
        self.worker.finished.connect(self.install_done)
        self.worker.start()

    def install_done(self, success):
        self.pbar.setValue(100)
        if success:
            self.stack.setCurrentIndex(8)
            self.nav_container.show()
            self.btn_back.hide()
            self.btn_next.setText(self.t("quit"))
            self.btn_next.setIcon(self.get_nav_icon("check_btn"))
            self.btn_next.setProperty("primary", "true")
            self.apply_styles()
            self.update_sidebar()
        else:
            QMessageBox.critical(self, "Error", "Installation failed. Check logs.")
            self.btn_back.setEnabled(True)
            self.btn_next.hide()

    def apply_styles(self):
        self.setStyleSheet(STYLES)


if __name__ == "__main__":
    app = QApplication(sys.argv)
    app.setStyle("Fusion")

    if not NetUtils.check_connection():
        QMessageBox.critical(None, "Network Error", TEXT["en"]["net_err"])
        sys.exit(1)

    if os.geteuid() != 0 and not SIMULATE:
        QMessageBox.critical(None, "Error", "Must run as root.")
        sys.exit(1)

    if not SIMULATE:
        for t in ["debootstrap", "mkfs.xfs", "mkfs.ext4", "pvcreate", "vgcreate", "lvcreate", "parted", "cryptsetup", "wipefs", "mkfs.vfat", "wget", "efibootmgr"]:
            if not shutil.which(t):
                QMessageBox.critical(None, "Error", f"Missing tool: {t}")
                sys.exit(1)

    gui = InstallerGUI()
    gui.apply_styles()
    gui.show()
    sys.exit(app.exec())
